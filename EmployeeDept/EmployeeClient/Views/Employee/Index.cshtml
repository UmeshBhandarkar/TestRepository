@{
}
@model IEnumerable<EmployeeClient.Models.Employee> 

 
        <table>
            <tr>
                <th>EmployeeId</th>
                <th>EmployeeName</th>
                <th>Salary</th>
                <th>City</th>
                <th>Dept No</th>
            </tr

            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.EmpId</td>
                    <td>@emp.EmpName</td>
                    <td>@emp.Salary</td>
                    <td>@emp.City</td>
                    <td>@emp.DeptNo</td>
                </tr>
            }
        </table>
